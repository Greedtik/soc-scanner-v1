#!/bin/bash

TMP_DIR="/tmp/socscanner-v1"
# แก้ไข URL ชี้ไปที่ Repo ของคุณที่เปิด Public ไว้
REPO="https://github.com/Greedtik/soc-scanner-v1.git"

echo "Downloading SOC Scanner..."
rm -rf "$TMP_DIR"

# ทำการ Clone โค้ด หากไม่สำเร็จจะแจ้งเตือนแทนการถามรหัสผ่านมั่วๆ
if git clone "$REPO" "$TMP_DIR"; then
    cd "$TMP_DIR" || exit 1
    chmod +x socscan.sh
    echo "Running SOC Scanner..."
    sudo bash socscan.sh "$@"
else
    echo "Error: Failed to download SOC Scanner."
    echo "Please check if the repository is public and the URL is correct."
    exit 1
fi
